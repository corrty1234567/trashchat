generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sender {
  CHEN
  ZUO
  SEVENTEEN
}

model Message {
  id               String    @id @default(cuid())
  sender           Sender
  text             String?
  imageUrl         String?   @map("image_url")
  imageUrls        String[]  @default([]) @map("image_urls")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  editedAt         DateTime? @map("edited_at")
  recalledAt       DateTime? @map("recalled_at")
  readAt           DateTime? @map("read_at")
  replyToMessageId String?   @map("reply_to_message_id")

  replyTo Message?  @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies Message[] @relation("MessageReplies")
  reads   MessageRead[]

  @@index([createdAt])
  @@index([replyToMessageId])
  @@map("messages")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  sender    Sender
  readAt    DateTime @default(now()) @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, sender])
  @@index([sender, readAt])
  @@map("message_reads")
}

model CallSignal {
  id        String   @id @default(cuid())
  type      String
  callId    String   @map("call_id")
  from      Sender
  to        Sender
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([to, createdAt])
  @@index([callId, createdAt])
  @@map("call_signals")
}
